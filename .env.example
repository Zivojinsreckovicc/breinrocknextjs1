# Sanity — connects this Next.js site to the (separately hosted) Studio.
# These are public, project-identifying values (safe to expose to the browser).
NEXT_PUBLIC_SANITY_PROJECT_ID=l0o6i6ub
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
NEXT_PUBLIC_SITE_URL=https://www.breinrock.com

# Tracking — public measurement IDs (optional).
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17816976579
NEXT_PUBLIC_GA4_ID=G-WW6R5ZQT5V

# reCAPTCHA v3 — site key is public (loads client script); secret verifies on the server.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Form delivery — server-only secrets (never use NEXT_PUBLIC_* for these).
WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
MAKE_DEMO_WEBHOOK=https://hook.eu2.make.com/your-demo-webhook-id
MAKE_WELCOME_WEBHOOK=https://hook.eu2.make.com/your-welcome-webhook-id

# Mailchimp embedded newsletter forms (public in rendered HTML, but kept out of source).
MAILCHIMP_ACTION=https://breinrock.us14.list-manage.com/subscribe/post?u=...&id=...&f_id=...
MAILCHIMP_TAGS=your-audience-tag-id
MAILCHIMP_GDPR_FIELD=gdpr[your-field-id]
MAILCHIMP_HONEYPOT=b_your_honeypot_field_name

# Curator.io — powers the live LinkedIn feed on /blog (server-side fetch).
CURATOR_API_KEY=
CURATOR_FEED_ID=
